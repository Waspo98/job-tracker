# Session signing key. Generate with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-me-to-a-long-random-value

# Set to 1 in public/production deployments so the app refuses to boot
# without a real SECRET_KEY.
REQUIRE_SECRET_KEY=1

# Local registration mode: first-user-only, open, or disabled.
REGISTRATION_MODE=first-user-only

# Host port exposed by docker compose.
JOB_TRACKER_PORT=5055

# SQLite database path inside the container.
DATABASE_PATH=/app/data/jobs.db

# Job scan cadence.
CHECK_INTERVAL_HOURS=4

# Optional Gmail SMTP settings. Alerts are queued for retry when sending fails.
SMTP_USER=yourgmail@gmail.com
SMTP_PASS=your-gmail-app-password

# Public origin for generated links and OIDC callback URLs when the app sits
# behind a proxy. Example: https://jobs.example.com
APP_BASE_URL=

# Set to 1 when the app is served over HTTPS. If left blank, the app enables
# secure cookies automatically when APP_BASE_URL starts with https://.
SESSION_COOKIE_SECURE=

# Optional comma-separated host allow-list. Example: jobs.example.com
TRUSTED_HOSTS=

# Optional Authentik / OpenID Connect SSO.
# In Authentik, configure the redirect URI as:
# https://jobs.example.com/auth/authentik/callback
AUTHENTIK_ENABLED=0
AUTHENTIK_ISSUER_URL=https://auth.example.com/application/o/job-tracker/
AUTHENTIK_CLIENT_ID=
AUTHENTIK_CLIENT_SECRET=
AUTHENTIK_DISPLAY_NAME=Authentik
AUTHENTIK_LOGIN_BUTTON_TEXT=Log in with your SSO account
AUTHENTIK_SCOPES=openid email profile
AUTHENTIK_AUTO_REGISTER=1
AUTHENTIK_REQUIRE_VERIFIED_EMAIL=1
AUTHENTIK_DISABLE_PASSWORD_LOGIN=0

# Optional browser push notifications. Generate a VAPID keypair once and keep
# the private key stable so existing browser subscriptions stay valid.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# Log verbosity: DEBUG, INFO, WARNING, ERROR.
LOG_LEVEL=INFO
